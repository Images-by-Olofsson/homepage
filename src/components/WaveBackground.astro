---
// src/components/WaveBackground.astro
const { opacity = "opacity-30", theme = "cyan" } = Astro.props;

const mainColor = theme === 'purple' ? '#c026d3' : '#4fd1c5';
const secondaryColor = theme === 'purple' ? '#db2777' : '#22d3ee';
const pulseMain = theme === 'purple' ? '#f0abfc' : '#a5f3fc';
const pulseSec = theme === 'purple' ? '#fbcfe8' : '#cffafe';
const pulseCore = theme === 'purple' ? '#fdf4ff' : '#f0fdfa';
---

<div
  class={`fixed inset-0 w-full h-full pointer-events-none -z-10 bg-neutral-900 ${opacity}`}
  data-wave-theme={theme}
  data-pulse-main={pulseMain}
  data-pulse-sec={pulseSec}
>
    <svg id="wave-svg" class="w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <defs>
            <linearGradient id="gradMain" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" style={`stop-color:${mainColor};stop-opacity:0`} />
                <stop offset="50%" style={`stop-color:${mainColor};stop-opacity:0.5`} />
                <stop offset="100%" style={`stop-color:${mainColor};stop-opacity:0`} />
            </linearGradient>

            <linearGradient id="gradSec" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" style={`stop-color:${secondaryColor};stop-opacity:0`} />
                <stop offset="30%" style={`stop-color:${secondaryColor};stop-opacity:0.3`} />
                <stop offset="100%" style={`stop-color:${secondaryColor};stop-opacity:0`} />
            </linearGradient>

            <filter id="pulseGlowSoft" x="-100%" y="-100%" width="300%" height="300%">
                <feGaussianBlur stdDeviation="22" />
            </filter>
            <filter id="pulseGlowMid" x="-100%" y="-100%" width="300%" height="300%">
                <feGaussianBlur stdDeviation="9" />
            </filter>
            <filter id="pulseGlowSharp" x="-100%" y="-100%" width="300%" height="300%">
                <feGaussianBlur stdDeviation="2.5" />
            </filter>

            <radialGradient id="pulseHaloGradient">
                <stop offset="0%" style={`stop-color:${pulseMain};stop-opacity:0.85`} />
                <stop offset="40%" style={`stop-color:${pulseMain};stop-opacity:0.35`} />
                <stop offset="100%" style={`stop-color:${pulseMain};stop-opacity:0`} />
            </radialGradient>

            <radialGradient id="pulseMidGradient">
                <stop offset="0%" style={`stop-color:${pulseSec};stop-opacity:1`} />
                <stop offset="60%" style={`stop-color:${pulseSec};stop-opacity:0.5`} />
                <stop offset="100%" style={`stop-color:${pulseSec};stop-opacity:0`} />
            </radialGradient>

            <radialGradient id="pulseCoreGradient">
                <stop offset="0%" style={`stop-color:${pulseCore};stop-opacity:1`} />
                <stop offset="50%" style={`stop-color:${pulseCore};stop-opacity:0.6`} />
                <stop offset="100%" style={`stop-color:${pulseCore};stop-opacity:0`} />
            </radialGradient>
        </defs>

        <g id="wave-group">
            <path id="wave1" d="M-1000 300 Q 250 100 800 300 T 2600 300" fill="none" stroke="url(#gradMain)" stroke-width="1" data-pulse-path="true" />
            <path id="wave2" d="M-1000 500 Q 250 700 800 500 T 2600 500" fill="none" stroke="url(#gradMain)" stroke-width="1.5" data-pulse-path="true" />
            <path id="wave3" d="M-1000 700 Q 250 500 800 700 T 2600 700" fill="none" stroke="url(#gradMain)" stroke-width="0.5" data-pulse-path="true" />

            <path id="thread1" d="M-1000 200 Q 400 400 900 200 T 2600 200" fill="none" stroke="url(#gradSec)" stroke-width="0.5" class="opacity-50" data-pulse-path="true" />
            <path id="thread2" d="M-1000 800 Q 600 600 1100 800 T 2600 800" fill="none" stroke="url(#gradSec)" stroke-width="0.8" class="opacity-60" data-pulse-path="true" />
        </g>

        <g id="box-trail-group"></g>

        <g id="pulse-group">
            <g id="pulse-blob-1" opacity="0">
                <ellipse rx="55" ry="22" fill="url(#pulseHaloGradient)" filter="url(#pulseGlowSoft)" />
                <ellipse rx="32" ry="11" fill="url(#pulseMidGradient)" filter="url(#pulseGlowMid)" />
                <ellipse rx="10" ry="3" fill="url(#pulseCoreGradient)" filter="url(#pulseGlowSharp)" opacity="0.75" />
            </g>
            <g id="pulse-blob-2" opacity="0">
                <ellipse rx="55" ry="22" fill="url(#pulseHaloGradient)" filter="url(#pulseGlowSoft)" />
                <ellipse rx="32" ry="11" fill="url(#pulseMidGradient)" filter="url(#pulseGlowMid)" />
                <ellipse rx="10" ry="3" fill="url(#pulseCoreGradient)" filter="url(#pulseGlowSharp)" opacity="0.75" />
            </g>
        </g>
    </svg>
</div>

<script>
    type Speeds = { w1: number; w2: number; w3: number; t1: number; t2: number };

    const wave1 = document.getElementById('wave1') as SVGPathElement | null;
    const wave2 = document.getElementById('wave2') as SVGPathElement | null;
    const wave3 = document.getElementById('wave3') as SVGPathElement | null;
    const thread1 = document.getElementById('thread1') as SVGPathElement | null;
    const thread2 = document.getElementById('thread2') as SVGPathElement | null;
    const svg = document.getElementById('wave-svg') as unknown as SVGSVGElement | null;
    const blob1 = document.getElementById('pulse-blob-1') as SVGGElement | null;
    const blob2 = document.getElementById('pulse-blob-2') as SVGGElement | null;
    const boxGroup = document.getElementById('box-trail-group') as SVGGElement | null;
    const wrapper = svg?.parentElement;

    const speeds: Speeds = { w1: 0.5, w2: -0.8, w3: 1.2, t1: 1.8, t2: -1.5 };

    function getSpeedKey(id: string): keyof Speeds | null {
        if (id === 'wave1') return 'w1';
        if (id === 'wave2') return 'w2';
        if (id === 'wave3') return 'w3';
        if (id === 'thread1') return 't1';
        if (id === 'thread2') return 't2';
        return null;
    }

    function onScroll() {
        const scrollY = window.scrollY;
        if (wave1) wave1.style.transform = `translateX(${scrollY * speeds.w1}px)`;
        if (wave2) wave2.style.transform = `translateX(${scrollY * speeds.w2}px)`;
        if (wave3) wave3.style.transform = `translateX(${scrollY * speeds.w3}px)`;
        if (thread1) thread1.style.transform = `translateX(${scrollY * speeds.t1}px)`;
        if (thread2) thread2.style.transform = `translateX(${scrollY * speeds.t2}px)`;
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    type BoxRect = { left: number; right: number; top: number; bottom: number; cx: number; cy: number; r: number };
    type PulsePath = { kind: 'thread'; id: string; pathTx: number } | { kind: 'box'; cx: number; cy: number };

    if (svg && blob1 && blob2 && wrapper) {
        const pulseMain = wrapper.getAttribute('data-pulse-main') || '#a5f3fc';
        const pulseSec = wrapper.getAttribute('data-pulse-sec') || '#cffafe';

        const wavePaths = Array.from(document.querySelectorAll<SVGPathElement>('[data-pulse-path="true"]'));
        const NS = 'http://www.w3.org/2000/svg';

        function buildBoxPath(rect: DOMRect): string {
            const r = 16;
            const x = rect.left, y = rect.top, w = rect.width, h = rect.height;
            return [
                `M ${x + r} ${y}`,
                `H ${x + w - r}`,
                `A ${r} ${r} 0 0 1 ${x + w} ${y + r}`,
                `V ${y + h - r}`,
                `A ${r} ${r} 0 0 1 ${x + w - r} ${y + h}`,
                `H ${x + r}`,
                `A ${r} ${r} 0 0 1 ${x} ${y + h - r}`,
                `V ${y + r}`,
                `A ${r} ${r} 0 0 1 ${x + r} ${y}`,
                `Z`,
            ].join(' ');
        }

        function clearBoxGroup() {
            if (!boxGroup) return;
            while (boxGroup.firstChild) boxGroup.removeChild(boxGroup.firstChild);
        }

        function refreshBoxPaths(): { paths: SVGPathElement[]; rects: DOMRect[] } {
            if (!boxGroup) return { paths: [], rects: [] };
            clearBoxGroup();
            const targets = document.querySelectorAll<HTMLElement>('[data-trail-box]');
            const paths: SVGPathElement[] = [];
            const rects: DOMRect[] = [];
            targets.forEach((el, idx) => {
                const rect = el.getBoundingClientRect();
                if (rect.width < 20 || rect.height < 20) return;
                if (rect.bottom < 0 || rect.top > window.innerHeight) return;
                const p = document.createElementNS(NS, 'path');
                p.setAttribute('id', `trail-box-${idx}`);
                p.setAttribute('d', buildBoxPath(rect));
                p.setAttribute('fill', 'none');
                p.setAttribute('stroke', 'transparent');
                p.setAttribute('data-trail-box-path', 'true');
                boxGroup.appendChild(p);
                paths.push(p);
                rects.push(rect);
            });
            return { paths, rects };
        }

        function updatePulseColors(isSecondary: boolean) {
            const haloColor = isSecondary ? pulseSec : pulseMain;
            const midColor = isSecondary ? pulseMain : pulseSec;

            const haloStops = document.querySelectorAll('#pulseHaloGradient stop');
            if (haloStops[0]) haloStops[0].setAttribute('style', `stop-color:${haloColor};stop-opacity:0.85`);
            if (haloStops[1]) haloStops[1].setAttribute('style', `stop-color:${haloColor};stop-opacity:0.35`);
            if (haloStops[2]) haloStops[2].setAttribute('style', `stop-color:${haloColor};stop-opacity:0`);

            const midStops = document.querySelectorAll('#pulseMidGradient stop');
            if (midStops[0]) midStops[0].setAttribute('style', `stop-color:${midColor};stop-opacity:1`);
            if (midStops[1]) midStops[1].setAttribute('style', `stop-color:${midColor};stop-opacity:0.5`);
            if (midStops[2]) midStops[2].setAttribute('style', `stop-color:${midColor};stop-opacity:0`);
        }

        function rectExpand(rect: DOMRect, pad: number): BoxRect {
            return {
                left: rect.left - pad,
                right: rect.right + pad,
                top: rect.top - pad,
                bottom: rect.bottom + pad,
                cx: rect.left + rect.width / 2,
                cy: rect.top + rect.height / 2,
                r: 16,
            };
        }

        function pointInBox(x: number, y: number, b: BoxRect): boolean {
            return x >= b.left && x <= b.right && y >= b.top && y <= b.bottom;
        }

        function findBoxIntersection(
            path: SVGPathElement,
            pathTx: number,
            boxes: BoxRect[]
        ): { boxIdx: number; entryLen: number; exitLen: number } | null {
            const total = path.getTotalLength();
            const step = 4;
            let activeBox = -1;
            let entryLen = -1;
            for (let len = 0; len <= total; len += step) {
                const pt = path.getPointAtLength(len);
                const x = pt.x + pathTx;
                const y = pt.y;
                for (let bi = 0; bi < boxes.length; bi++) {
                    if (pointInBox(x, y, boxes[bi])) {
                        if (activeBox === -1) {
                            activeBox = bi;
                            entryLen = len;
                        } else if (activeBox === bi) {
                            // still in same box, continue
                        }
                        break;
                    }
                }
                if (activeBox !== -1) {
                    // Check if we left
                    const stillIn = pointInBox(x, y, boxes[activeBox]);
                    if (!stillIn) {
                        return { boxIdx: activeBox, entryLen, exitLen: len };
                    }
                }
            }
            return null;
        }

        function buildBoxHalfPath(box: BoxRect, half: 'top' | 'bottom'): SVGPathElement {
            const r = box.r;
            const x = box.left + 16; // un-pad: revert to original rect
            const y = box.top + 16;
            const w = (box.right - box.left) - 32;
            const h = (box.bottom - box.top) - 32;
            // Entry-point assumed left side at cy; exit-point right side at cy
            const yMid = box.cy;
            let d: string;
            if (half === 'top') {
                d = [
                    `M ${x} ${yMid}`,
                    `V ${y + r}`,
                    `A ${r} ${r} 0 0 1 ${x + r} ${y}`,
                    `H ${x + w - r}`,
                    `A ${r} ${r} 0 0 1 ${x + w} ${y + r}`,
                    `V ${yMid}`,
                ].join(' ');
            } else {
                d = [
                    `M ${x} ${yMid}`,
                    `V ${y + h - r}`,
                    `A ${r} ${r} 0 0 0 ${x + r} ${y + h}`,
                    `H ${x + w - r}`,
                    `A ${r} ${r} 0 0 0 ${x + w} ${y + h - r}`,
                    `V ${yMid}`,
                ].join(' ');
            }
            const p = document.createElementNS(NS, 'path');
            p.setAttribute('d', d);
            p.setAttribute('fill', 'none');
            p.setAttribute('stroke', 'transparent');
            return p;
        }

        function applyTransform(blob: SVGGElement, x: number, y: number, angle: number) {
            blob.setAttribute('transform', `translate(${x} ${y}) rotate(${angle})`);
        }

        function tangentAngle(path: SVGPathElement, len: number, total: number): number {
            const delta = Math.max(1, total * 0.002);
            const before = path.getPointAtLength(Math.max(0, len - delta));
            const after = path.getPointAtLength(Math.min(total, len + delta));
            return Math.atan2(after.y - before.y, after.x - before.x) * (180 / Math.PI);
        }

        function fadeFactor(t: number): number {
            if (t < 0.18) return t / 0.18;
            if (t > 0.82) return (1 - t) / 0.18;
            return 1;
        }

        let currentTimeout: number | null = null;
        let isPulsing = false;

        function runThreadPulse(path: SVGPathElement, durationMs: number) {
            if (!blob1 || !blob2) return;
            isPulsing = true;
            const total = path.getTotalLength();
            const isSecondary =
                (path.getAttribute('stroke') || '').includes('gradSec') ||
                path.id === 'thread1' ||
                path.id === 'thread2';
            updatePulseColors(isSecondary);

            const speedKey = getSpeedKey(path.id);
            const { rects: boxRects } = refreshBoxPaths();
            const boxes: BoxRect[] = boxRects.map(r => rectExpand(r, 4));

            const pathTx0 = speedKey ? window.scrollY * speeds[speedKey] : 0;
            const hit = findBoxIntersection(path, pathTx0, boxes);

            // Velocity = pixels per ms across full pathLength over full duration
            const velocity = total / durationMs;

            const startTime = performance.now();
            blob2.setAttribute('opacity', '0');

            // PHASE 1: glide from 0 to entry (or full if no hit)
            const entryLen = hit ? hit.entryLen : total;
            const exitLen = hit ? hit.exitLen : total;
            const phase1Duration = entryLen / velocity;

            // PHASE 2: split around box from entryLen at velocity
            let topPath: SVGPathElement | null = null;
            let bottomPath: SVGPathElement | null = null;
            let phase2Duration = 0;
            if (hit) {
                topPath = buildBoxHalfPath(boxes[hit.boxIdx], 'top');
                bottomPath = buildBoxHalfPath(boxes[hit.boxIdx], 'bottom');
                if (boxGroup) {
                    boxGroup.appendChild(topPath);
                    boxGroup.appendChild(bottomPath);
                }
                const topLen = topPath.getTotalLength();
                const bottomLen = bottomPath.getTotalLength();
                const maxHalf = Math.max(topLen, bottomLen);
                phase2Duration = maxHalf / velocity;
            }

            // PHASE 3: glide from exitLen to end at velocity
            const phase3Duration = hit ? (total - exitLen) / velocity : 0;

            function step(now: number) {
                if (!blob1 || !blob2) return;
                const elapsed = now - startTime;
                const totalTime = phase1Duration + phase2Duration + phase3Duration;
                const globalT = Math.min(elapsed / totalTime, 1);
                const fade = fadeFactor(globalT);
                const pathTx = speedKey ? window.scrollY * speeds[speedKey] : 0;

                if (elapsed <= phase1Duration) {
                    // Phase 1: single blob on path
                    const len = elapsed * velocity;
                    const pt = path.getPointAtLength(Math.min(len, total));
                    const angle = tangentAngle(path, Math.min(len, total), total);
                    applyTransform(blob1, pt.x + pathTx, pt.y, angle);
                    blob1.setAttribute('opacity', String(fade));
                    blob2.setAttribute('opacity', '0');
                } else if (hit && elapsed <= phase1Duration + phase2Duration) {
                    // Phase 2: split around box
                    const inPhase2 = elapsed - phase1Duration;
                    if (topPath && bottomPath) {
                        const topLen = topPath.getTotalLength();
                        const bottomLen = bottomPath.getTotalLength();
                        const tDist = Math.min(inPhase2 * velocity, topLen);
                        const bDist = Math.min(inPhase2 * velocity, bottomLen);

                        const tp = topPath.getPointAtLength(tDist);
                        const ta = tangentAngle(topPath, tDist, topLen);
                        applyTransform(blob1, tp.x, tp.y, ta);
                        blob1.setAttribute('opacity', String(fade));

                        const bp = bottomPath.getPointAtLength(bDist);
                        const ba = tangentAngle(bottomPath, bDist, bottomLen);
                        applyTransform(blob2, bp.x, bp.y, ba);
                        blob2.setAttribute('opacity', String(fade));
                    }
                } else if (hit) {
                    // Phase 3: single blob continues from exitLen
                    const inPhase3 = elapsed - phase1Duration - phase2Duration;
                    const len = exitLen + inPhase3 * velocity;
                    const clamped = Math.min(len, total);
                    const pt = path.getPointAtLength(clamped);
                    const angle = tangentAngle(path, clamped, total);
                    applyTransform(blob1, pt.x + pathTx, pt.y, angle);
                    blob1.setAttribute('opacity', String(fade));
                    blob2.setAttribute('opacity', '0');
                }

                if (elapsed < (phase1Duration + phase2Duration + phase3Duration) && globalT < 1) {
                    requestAnimationFrame(step);
                } else {
                    blob1.setAttribute('opacity', '0');
                    blob2.setAttribute('opacity', '0');
                    if (topPath && boxGroup && topPath.parentNode) boxGroup.removeChild(topPath);
                    if (bottomPath && boxGroup && bottomPath.parentNode) boxGroup.removeChild(bottomPath);
                    isPulsing = false;
                }
            }
            requestAnimationFrame(step);
        }

        function runBoxPulse(boxPath: SVGPathElement, durationMs: number) {
            if (!blob1 || !blob2) return;
            isPulsing = true;
            updatePulseColors(true);
            const total = boxPath.getTotalLength();
            const startTime = performance.now();
            blob2.setAttribute('opacity', '0');
            function step(now: number) {
                if (!blob1) return;
                const elapsed = now - startTime;
                const t = Math.min(elapsed / durationMs, 1);
                const eased = t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
                const len = eased * total;
                const pt = boxPath.getPointAtLength(len);
                const angle = tangentAngle(boxPath, len, total);
                applyTransform(blob1, pt.x, pt.y, angle);
                blob1.setAttribute('opacity', String(fadeFactor(t)));
                if (t < 1) requestAnimationFrame(step);
                else {
                    blob1.setAttribute('opacity', '0');
                    isPulsing = false;
                }
            }
            requestAnimationFrame(step);
        }

        function pickAndPulse() {
            if (isPulsing) {
                schedule();
                return;
            }
            const { paths: boxPaths } = refreshBoxPaths();
            const allTargets: { kind: 'wave' | 'box'; path: SVGPathElement }[] = [
                ...wavePaths.map(p => ({ kind: 'wave' as const, path: p })),
                ...boxPaths.map(p => ({ kind: 'box' as const, path: p })),
            ];
            if (allTargets.length === 0) {
                schedule();
                return;
            }
            const choice = allTargets[Math.floor(Math.random() * allTargets.length)];
            if (choice.kind === 'wave') {
                runThreadPulse(choice.path, 18000 + Math.random() * 8000);
            } else {
                runBoxPulse(choice.path, 14000 + Math.random() * 4000);
            }
            schedule();
        }

        function schedule() {
            if (currentTimeout) clearTimeout(currentTimeout);
            const delay = 3500 + Math.random() * 5500;
            currentTimeout = window.setTimeout(pickAndPulse, delay);
        }

        const startDelay = 1500 + Math.random() * 2000;
        currentTimeout = window.setTimeout(pickAndPulse, startDelay);
    }
</script>

<style>
    path {
        transition: transform 0.1s linear;
        will-change: transform;
    }
    #pulse-blob-1, #pulse-blob-2 {
        mix-blend-mode: screen;
    }
    #pulse-blob-1 ellipse, #pulse-blob-2 ellipse {
        transform-box: fill-box;
        transform-origin: center;
    }
</style>
